# Copiá este archivo a .env.local y completá con tus credenciales.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (opcional): clave pública VAPID. Generala con:
#   npx web-push generate-vapid-keys
# La pública va acá; la privada va como secreto en Supabase (VAPID_PRIVATE_KEY).
VITE_VAPID_PUBLIC_KEY=

# Strava (opcional): Client ID de tu app de API de Strava (es público).
# El Client Secret NO va acá: se guarda como secreto en Supabase (STRAVA_CLIENT_SECRET).
VITE_STRAVA_CLIENT_ID=

# Fitbit y Oura (opcionales): Client ID público de cada app. Los Secret van a
# Supabase (FITBIT_CLIENT_SECRET / OURA_CLIENT_SECRET).
VITE_FITBIT_CLIENT_ID=
VITE_OURA_CLIENT_ID=
