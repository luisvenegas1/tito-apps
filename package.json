{
  "name": "tito-apps",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo de Tito Apps (GolPay, MoneyTrack, SplitPay).",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "golpay:dev": "pnpm --filter golpay dev",
    "golpay:build": "pnpm --filter golpay build",
    "golpay:test": "pnpm --filter golpay test",
    "titoapps:dev": "pnpm --filter titoapps dev",
    "titoapps:build": "pnpm --filter titoapps build",
    "titoapps:test": "pnpm --filter titoapps test",
    "nutricoach:dev": "pnpm --filter nutricoach dev",
    "nutricoach:build": "pnpm --filter nutricoach build",
    "nutricoach:test": "pnpm --filter nutricoach test"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
