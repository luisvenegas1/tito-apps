{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "esnext",
    "target": "es2020",
    "moduleResolution": "bundler",
    "lib": ["es2020", "dom", "dom.iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "typeRoots": ["apps/golpay/node_modules/@types"],
    "paths": {
      "react": ["apps/golpay/node_modules/react"],
      "react/jsx-runtime": ["apps/golpay/node_modules/react/jsx-runtime"],
      "react-dom": ["apps/golpay/node_modules/react-dom"]
    }
  },
  "include": ["packages/ui/src/**/*", "packages/brand/src/**/*"]
}
